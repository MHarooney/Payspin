{
  "mcpServers": {
    "dart": {
      "type": "stdio",
      "command": "${FLUTTER_DART:-dart}",
      "args": [
        "mcp-server",
        "--force-roots-fallback"
      ],
      "env": {}
    },
    "browsermcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@browsermcp/mcp"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {}
    },
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp"
    }
  }
}