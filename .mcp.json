{
  "mcpServers": {
    "payspin-design": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "scripts/mcp/payspin-design-filesystem.sh"
      ],
      "env": {}
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "dart": {
      "type": "stdio",
      "command": "${FLUTTER_DART:-/Users/7arooney/development/flutter/bin/dart}",
      "args": [
        "mcp-server",
        "--force-roots-fallback"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {}
    },
    "browsermcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@browsermcp/mcp"
      ],
      "env": {}
    },
    "mobile-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@mobilenext/mobile-mcp@latest"
      ],
      "env": {
        "GO_IOS_PATH": "/Users/7arooney/CodeWork/Payspin_2026/scripts/dev/ios-mcp-wrapper.sh"
      }
    },
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp"
    }
  }
}
