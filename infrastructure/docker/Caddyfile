# Production reverse proxy — payer web + ops portal on separate hostnames.
{
	email {$ACME_EMAIL:payspin.app@gmail.com}
}

# Public payer web + consumer API (/v1).
{$SITE_ADDRESS:pay.payspin.io} {
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	handle /v1/* {
		reverse_proxy api:3001
	}

	handle {
		reverse_proxy web:3000
	}
}

# Internal ops portal (admin UI + /admin/v1 API).
{$OPS_SITE_ADDRESS:ops.payspin.io} {
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	handle /admin/v1/* {
		reverse_proxy ops-api:3002
	}

	handle {
		reverse_proxy ops-web:3003
	}
}
