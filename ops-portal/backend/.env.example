DATABASE_URL=postgresql://payspin:payspin_dev@localhost:5435/payspin?schema=public
REDIS_URL=redis://localhost:6381
# Dedicated port var (avoids colliding with consumer backend's PORT=3001 in this monorepo):
OPS_API_PORT=3002
ADMIN_JWT_SECRET=change-me-in-production-min-32-chars-long
ADMIN_JWT_EXPIRES_IN=15m
OPS_CORS_ORIGIN=http://localhost:3003
# Optional — used only for best-effort Yapily health reporting on /system:
YAPILY_APPLICATION_ID=
YAPILY_APPLICATION_SECRET=
PIS_GATEWAY=yapily
