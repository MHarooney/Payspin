# Production env for docker compose on Hetzner (copy to backend/.env.production on server)
# Generate secrets: openssl rand -hex 32

POSTGRES_USER=payspin
POSTGRES_PASSWORD=change-me-generate-with-openssl
POSTGRES_DB=payspin

DATABASE_URL=postgresql://payspin:change-me-generate-with-openssl@postgres:5432/payspin?schema=public

# Redis requires a password in production.
REDIS_PASSWORD=change-me-generate-with-openssl
REDIS_URL=redis://:change-me-generate-with-openssl@redis:6379

PORT=3001
NODE_ENV=production

# Reverse proxy. Leave SITE_ADDRESS as ":80" for IP-only (no TLS); set to a
# domain (e.g. pay.payspin.app) for automatic Let's Encrypt HTTPS.
SITE_ADDRESS=:80
ACME_EMAIL=payspin.app@gmail.com

# Set to your server public IP or domain after deploy
API_BASE_URL=http://YOUR_SERVER_IP
PAYER_WEB_URL=http://YOUR_SERVER_IP

# Deep link the bank-connect callback bounces the mobile app back to.
MOBILE_CONNECT_REDIRECT=payspin://bank-callback

JWT_SECRET=change-me-generate-with-openssl
JWT_EXPIRES_IN=7d
IBAN_ENCRYPTION_KEY=change-me-generate-with-openssl-64-hex-chars

YAPILY_APP_KEY=
YAPILY_APP_SECRET=
YAPILY_WEBHOOK_SECRET=
YAPILY_BASE_URL=https://api.yapily.com
YAPILY_DEFAULT_INSTITUTION=modelo-sandbox
YAPILY_DEFAULT_COUNTRY=NL
