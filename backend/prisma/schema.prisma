generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  passwordHash    String         @map("password_hash")
  displayName     String?        @map("display_name")
  phoneE164       String?        @map("phone_e164")
  phoneVerifiedAt DateTime?      @map("phone_verified_at")
  lastLoginAt     DateTime?      @map("last_login_at")
  lastSeenAt      DateTime?      @map("last_seen_at")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  bankAccounts    BankAccount[]
  paymentLinks    PaymentLink[]
  deviceTokens    DeviceToken[]
  notifications   Notification[]
  supportThreads  SupportThread[]

  @@map("users")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  fcmToken  String   @map("fcm_token")
  platform  String   @default("unknown")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fcmToken])
  @@index([userId])
  @@map("device_tokens")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

model BankAccount {
  id                 String        @id @default(uuid())
  userId             String        @map("user_id")
  ibanEncrypted      String        @map("iban_encrypted")
  ibanIv             String        @map("iban_iv")
  ibanLast4          String        @map("iban_last4")
  accountHolder      String        @map("account_holder")
  bankName           String?       @map("bank_name")
  verified           Boolean       @default(false)
  isPrimary          Boolean       @default(false) @map("is_primary")
  verificationSource String?       @map("verification_source")
  yapilyConnectionId String?       @map("yapily_connection_id")
  yapilyInstitutionId String?      @map("yapily_institution_id")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentLinks       PaymentLink[]
  bankConnections    BankConnection[]

  @@index([userId])
  @@map("bank_accounts")
}

model BankConnection {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  institutionId   String    @map("institution_id")
  yapilyAuthId    String?   @map("yapily_auth_id")
  status          String    @default("PENDING")
  bankAccountId   String?   @map("bank_account_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  bankAccount     BankAccount? @relation(fields: [bankAccountId], references: [id])

  @@index([userId])
  @@map("bank_connections")
}

model PaymentLink {
  id             String            @id @default(uuid())
  shortCode      String            @unique @map("short_code")
  payeeUserId    String            @map("payee_user_id")
  bankAccountId  String            @map("bank_account_id")
  amountCents    Int?              @map("amount_cents")
  currency       String            @default("EUR")
  description    String?
  status         PaymentLinkStatus @default(ACTIVE)
  linkType       PaymentLinkType   @default(SINGLE) @map("link_type")
  maxUses        Int?              @map("max_uses")
  useCount       Int               @default(0) @map("use_count")
  expiresAt      DateTime?         @map("expires_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  payeeUser      User              @relation(fields: [payeeUserId], references: [id], onDelete: Cascade)
  bankAccount    BankAccount       @relation(fields: [bankAccountId], references: [id])
  payments       Payment[]

  @@index([payeeUserId])
  @@index([status])
  @@map("payment_links")
}

model Payment {
  id                     String        @id @default(uuid())
  paymentLinkId          String        @map("payment_link_id")
  yapilyPaymentId        String?       @unique @map("yapily_payment_id")
  yapilyAuthRequestId    String?       @map("yapily_auth_request_id")
  yapilyConsentToken     String?       @map("yapily_consent_token")
  paymentRequestSnapshot Json?         @map("payment_request_snapshot")
  amountCents            Int           @map("amount_cents")
  currency               String        @default("EUR")
  status                 PaymentStatus @default(AWAITING_AUTHORIZATION)
  payerBankName          String?       @map("payer_bank_name")
  idempotencyKey         String?       @unique @map("idempotency_key")
  initiatedAt            DateTime      @default(now()) @map("initiated_at")
  completedAt            DateTime?     @map("completed_at")
  webhookRaw             Json?         @map("webhook_raw")
  paymentLink            PaymentLink   @relation(fields: [paymentLinkId], references: [id], onDelete: Cascade)

  @@index([paymentLinkId])
  @@index([status])
  @@map("payments")
}

model WebhookEvent {
  id          String    @id @default(uuid())
  eventId     String    @unique @map("event_id")
  eventType   String    @map("event_type")
  payload     Json
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("webhook_events")
}

model Circle {
  id                    String         @id @default(uuid())
  name                  String
  hostUserId            String         @map("host_user_id")
  memberCount           Int            @map("member_count")
  contributionCents     Int            @map("contribution_cents")
  cycleDurationDays     Int            @map("cycle_duration_days")
  inviteCode            String         @unique @map("invite_code")
  smartContractAddress  String?        @map("smart_contract_address")
  status                String         @default("DRAFT")
  currentRound          Int            @default(0) @map("current_round")
  startedAt             DateTime?      @map("started_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  members               CircleMember[]

  @@index([hostUserId])
  @@map("circles")
}

model CircleMember {
  id            String   @id @default(uuid())
  circleId      String   @map("circle_id")
  userId        String   @map("user_id")
  moneriumIban  String?  @map("monerium_iban")
  walletAddress String?  @map("wallet_address")
  payoutOrder   Int      @map("payout_order")
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now()) @map("created_at")
  circle        Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@unique([circleId, userId])
  @@index([circleId])
  @@index([userId])
  @@map("circle_members")
}

// ---------------------------------------------------------------------------
// Ops Admin Portal (ops-portal/) — additive only. These models back the
// internal operations portal and never modify the consumer-facing tables
// above. Migrations are still generated from backend/ as the single source.
// ---------------------------------------------------------------------------

enum AdminRole {
  SUPER_ADMIN
  OPS
  SUPPORT
  READ_ONLY
}

model AdminUser {
  id           String            @id @default(uuid())
  email        String            @unique
  passwordHash String            @map("password_hash")
  displayName  String?           @map("display_name")
  role         AdminRole         @default(OPS)
  isActive     Boolean           @default(true) @map("is_active")
  lastLoginAt  DateTime?         @map("last_login_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  auditEvents  AdminAuditEvent[]

  @@map("admin_users")
}

model AdminAuditEvent {
  id          String     @id @default(uuid())
  adminUserId String?    @map("admin_user_id")
  adminEmail  String     @map("admin_email")
  action      String
  targetType  String?    @map("target_type")
  targetId    String?    @map("target_id")
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?    @map("user_agent")
  createdAt   DateTime   @default(now()) @map("created_at")
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action])
  @@map("admin_audit_events")
}

model FeatureFlag {
  key            String   @id
  label          String
  description    String?
  enabled        Boolean  @default(false)
  category       String   @default("platform")
  updatedByEmail String?  @map("updated_by_email")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("feature_flags")
}

model PlatformConfig {
  key            String   @id
  label          String
  value          String
  valueType      String   @default("string") @map("value_type")
  group          String   @default("limits")
  description    String?
  updatedByEmail String?  @map("updated_by_email")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([group])
  @@map("platform_config")
}

model UserAdminState {
  userId         String   @id @map("user_id")
  status         String   @default("ACTIVE")
  kycTier        String?  @map("kyc_tier")
  kycStatus      String   @default("PENDING") @map("kyc_status")
  riskLevel      String   @default("LOW") @map("risk_level")
  note           String?
  frozenReason   String?  @map("frozen_reason")
  updatedByEmail String?  @map("updated_by_email")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("user_admin_states")
}

model ComplianceAlert {
  id         String   @id @default(uuid())
  type       String
  subject    String
  subjectRef String?  @map("subject_ref")
  rule       String
  severity   String   @default("MEDIUM")
  status     String   @default("OPEN")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("compliance_alerts")
}

model Dispute {
  id          String   @id @default(uuid())
  caseRef     String   @unique @map("case_ref")
  type        String
  amountCents Int      @map("amount_cents")
  currency    String   @default("EUR")
  parties     String
  status      String   @default("OPEN")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("disputes")
}

model SupportThread {
  id            String           @id @default(uuid())
  userId        String?          @map("user_id")
  userRef       String           @map("user_ref")
  subjectName   String           @map("subject_name")
  category      String?
  contextRef    String?          @map("context_ref")
  meta          String?
  status        String           @default("OPEN")
  unread        Boolean          @default(true)
  userUnread    Boolean          @default(false) @map("user_unread")
  lastMessageAt DateTime         @default(now()) @map("last_message_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  user          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages      SupportMessage[]

  @@index([status, lastMessageAt])
  @@index([userId, lastMessageAt])
  @@map("support_threads")
}

model SupportMessage {
  id         String        @id @default(uuid())
  threadId   String        @map("thread_id")
  direction  String        @default("IN")
  body       String
  authorName String        @map("author_name")
  createdAt  DateTime      @default(now()) @map("created_at")
  thread     SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("support_messages")
}

enum PaymentLinkStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  SETTLED
  COLLECTING
}

enum PaymentLinkType {
  SINGLE
  MULTI
}

enum PaymentStatus {
  AWAITING_AUTHORIZATION
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}
